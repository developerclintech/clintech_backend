APP_NAME="Clinics API"
ENVIRONMENT=local
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+asyncpg://clinics:clinics_dev_password@localhost:5432/clinics

DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_RECYCLE_SECONDS=1800
LOG_LEVEL=INFO
LOG_FORMAT=json
ENABLE_METRICS=true
AI_PROVIDER=mock
AI_MODEL_NAME=mock-clinical-summarizer
AI_REQUEST_TIMEOUT_SECONDS=30
AUDIT_LOG_ENABLED=true
PASSWORD_RESET_OTP_LENGTH=6
PASSWORD_RESET_OTP_EXPIRE_MINUTES=10
PASSWORD_RESET_OTP_MAX_ATTEMPTS=5
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@clinics.local
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=10
